# Application
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://peakpass:peakpass@postgres:5432/peakpass
DB_HOST=postgres
DB_PORT=5432
DB_USER=peakpass
DB_PASSWORD=peakpass
DB_NAME=peakpass

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Application secrets
JWT_SECRET=your-jwt-secret-change-in-production
API_KEY=your-api-key-change-in-production

# External services
PAYMENT_SERVICE_URL=https://api.payment-provider.example.com
PAYMENT_API_KEY=test-key-change-in-production
WEBHOOK_SIGNING_SECRET=

# Feature flags
ENABLE_RATE_LIMITING=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Performance tuning
DB_POOL_MIN=2
DB_POOL_MAX=10
REDIS_POOL_SIZE=10
