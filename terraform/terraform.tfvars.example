# Terraform Variables - Configuration Example
# 
# Copy this to terraform.tfvars and customize for your environment
# Sensitive values (passwords) should be provided via environment or -var flags
# 
# Usage:
#   terraform apply -var-file=terraform.tfvars -var="db_password=secure_password_123"

# AWS Region
aws_region = "us-east-1"

# Environment (dev, staging, prod)
environment = "prod"

# Application Name
app_name = "peakpass"

# ===== VPC Configuration =====
vpc_cidr = "10.0.0.0/16"

# Availability zones (must exist in chosen region)
availability_zones = ["us-east-1a", "us-east-1b"]

# ===== RDS PostgreSQL Configuration =====
db_engine_version       = "15.3"
db_instance_class       = "db.t3.micro"      # Change to db.t3.small+ for production
db_allocated_storage    = 20                  # Initial storage in GB
db_max_allocated_storage = 100               # Max autoscaling storage
db_backup_retention_days = 30                # Backup retention
db_name                  = "peakpass"
db_username              = "postgres"
# db_password        = "provide via -var flag"

# ===== Redis Configuration =====
redis_engine_version         = "7.0"
redis_node_type              = "cache.t3.micro"  # Change to cache.t3.small+ for production
redis_num_cache_clusters     = 2                 # >=2 enables automatic failover
redis_automatic_failover_enabled = true
redis_snapshot_retention_limit   = 5

# ===== ECS Fargate Configuration =====
container_port  = 3000
container_cpu   = 512               # 256-4096
container_memory = 1024             # 512-30720

# Task count and scaling
ecs_desired_count = 2               # Initial number of tasks
ecs_min_capacity  = 2               # Minimum for autoscaling
ecs_max_capacity  = 10              # Maximum for autoscaling

# Container image (ECR image URI)
container_image = "123456789.dkr.ecr.us-east-1.amazonaws.com/peakpass:latest"

# ===== Application Configuration =====
log_level                = "info"     # debug, info, warn, error
enable_rate_limiting     = true
rate_limit_requests      = 1000       # Per minute
graphql_max_complexity   = 5000

# ===== Monitoring & Alerts =====
enable_detailed_monitoring = true
enable_alarms              = true
alarm_email                = "alerts@example.com"  # Email for CloudWatch alarms

# ===== Additional Tags =====
tags = {
  Project     = "PeakPass"
  ManagedBy   = "Terraform"
  Owner       = "DevOps Team"
  CostCenter  = "Engineering"
}
