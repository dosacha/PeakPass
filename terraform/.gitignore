# Terraform Files to Ignore

# Local .terraform directories
**/.terraform/*

# .tfstate files (local state)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (contains sensitive data)
# Note: terraform.tfvars.example is tracked
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI config files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan

# Ignore lock files in development (track in CI/CD)
# .terraform.lock.hcl

# Ignore IDE files
.idea
*.swp
*.swo
.DS_Store
