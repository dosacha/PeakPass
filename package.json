{
  "name": "peakpass",
  "version": "0.1.0",
  "description": "High-demand workshop ticketing and digital pass issuance platform",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:concurrency": "jest --runInBand --config jest.integration.cjs src/tests/integration/concurrency.test.ts",
    "test:redis": "jest --runInBand --config jest.integration.cjs src/tests/integration/redis.test.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:up": "tsx src/infra/migrations/runner.ts up",
    "migrate:down": "tsx src/infra/migrations/runner.ts down",
    "seed": "tsx src/infra/seed.ts",
    "db:reset": "npm run migrate:down && npm run migrate:up && npm run seed",
    "load-test:baseline": "k6 run load-test/baseline.js",
    "load-test:spike": "k6 run load-test/spike.js",
    "load-test:sustained": "k6 run load-test/sustained.js",
    "load-test:callbacks": "k6 run load-test/payment-callback.js",
    "load-test:baseline:report": "k6 run --out json=load-test/results/baseline.json load-test/baseline.js",
    "load-test:spike:report": "k6 run --out json=load-test/results/spike.json load-test/spike.js",
    "load-test:sustained:report": "k6 run --out json=load-test/results/sustained.json load-test/sustained.js",
    "load-test:callbacks:report": "k6 run --out json=load-test/results/callbacks.json load-test/payment-callback.js",
    "docker:build": "docker build -t peakpass:latest .",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app"
  },
  "dependencies": {
    "fastify": "^4.25.0",
    "@fastify/cors": "^8.4.0",
    "@fastify/helmet": "^11.1.1",
    "@apollo/server": "^4.9.0",
    "graphql": "^16.8.0",
    "dataloader": "^2.2.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.0",
    "decimal.js": "^10.4.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "supertest": "^6.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
